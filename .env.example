# =============================================================
# SCANNO AI CHATBOT PLATFORM — Unified Environment Configuration
# =============================================================

# -------------------------------------------------------------
# FRONTEND CONFIGURATION (Next.js)
# -------------------------------------------------------------

# REQUIRED: OpenAI API Key (used for frontend's client-side OpenAI chat route)
# Get yours: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OPTIONAL: Brand / Business Configuration (exposed to Next.js client-side code)
NEXT_PUBLIC_CAR_DOCTOR_WEBSITE=https://scanno.qa
NEXT_PUBLIC_CAR_DOCTOR_PHONE=+97466532830
NEXT_PUBLIC_CAR_DOCTOR_BOOKING_URL=https://scanno.qa/booking
NEXT_PUBLIC_CURRENCY_SYMBOL=QAR


# -------------------------------------------------------------
# BACKEND CONFIGURATION (FastAPI)
# -------------------------------------------------------------

# REQUIRED: Database URL for user auth & history tracking (SQLite or PostgreSQL)
# Local SQLite default: sqlite:///./scanno_integrated.db
# Docker Compose Postgres default: postgresql://scanno_user:scanno_password@postgres:5432/scanno_db
DATABASE_URL=postgresql://scanno_user:scanno_password@postgres:5432/scanno_db

# REQUIRED: JWT signing secret key (long random string)
JWT_SECRET_KEY=generate_a_long_random_string_here

# OPTIONAL: Seed admin user details
ADMIN_EMAIL=admin@scanno.ai
ADMIN_PASSWORD=supersecurepassword

# REQUIRED: Redis host and port for temporary chat memory / state persistence
# Local default: localhost
# Docker Compose default: redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=scanno_redis_password
SESSION_TTL=3600
